<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventory Data Entry System</title>
    <style>
        :root {
            --primary-color: #4f46e5;
            --primary-hover: #4338ca;
            --background: #f3f4f6;
            --card-bg: #ffffff;
            --text: #1f2937;
            --border: #d1d5db;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--background);
            color: var(--text);
            margin: 0;
            padding: 40px 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            box-sizing: border-box;
        }

        .container {
            background-color: var(--card-bg);
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            width: 100%;
            max-width: 500px;
        }

        h2 {
            margin-top: 0;
            margin-bottom: 24px;
            color: #111827;
            font-size: 24px;
            text-align: center;
            border-bottom: 2px solid var(--background);
            padding-bottom: 12px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 6px;
            font-weight: 600;
            font-size: 14px;
            color: #374151;
        }

        .optional-label {
            font-weight: normal;
            font-size: 12px;
            color: #6b7280;
            margin-left: 4px;
        }

        input[type="text"],
        input[type="number"],
        select,
        textarea {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 15px;
            background-color: #fff;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
            box-sizing: border-box;
            font-family: inherit;
        }

        textarea {
            resize: vertical;
            min-height: 80px;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.15);
        }

        /* Readonly unit of measure styling */
        input[readonly] {
            background-color: #f9fafb;
            color: #6b7280;
            cursor: not-allowed;
        }

        .btn-submit {
            width: 100%;
            background-color: var(--primary-color);
            color: white;
            padding: 12px;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.15s ease-in-out;
            margin-top: 10px;
        }

        .btn-submit:hover {
            background-color: var(--primary-hover);
        }

        .message {
            margin-top: 15px;
            padding: 10px;
            border-radius: 6px;
            font-size: 14px;
            text-align: center;
            display: none;
        }

        .success {
            background-color: #def7ec;
            color: #03543f;
            display: block;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Data Entry Form</h2>
    <form id="dataEntryForm">
        
        <!-- Requestor -->
        <div class="form-group">
            <label for="requestor">Requestor Name</label>
            <input type="text" id="requestor" placeholder="Enter requestor's name" required>
        </div>

        <!-- Released Item (Dropdown) -->
        <div class="form-group">
            <label for="releasedItem">Released Item</label>
            <select id="releasedItem" required>
                <option value="" disabled selected>-- Select an Item --</option>
                <!-- Items populated dynamically from our list -->
            </select>
        </div>

        <!-- Unit of Measure (Auto-filled) -->
        <div class="form-group">
            <label for="unitOfMeasure">Unit of Measure</label>
            <input type="text" id="unitOfMeasure" readonly placeholder="Select an item first">
        </div>

        <!-- Quantity Released -->
        <div class="form-group">
            <label for="quantity">Quantity Released</label>
            <input type="number" id="quantity" min="1" step="any" placeholder="Enter quantity (numbers only)" required>
        </div>

        <!-- Action -->
        <div class="form-group">
            <label for="action">Action</label>
            <select id="action" required>
                <option value="" disabled selected>-- Select Action --</option>
                <option value="issued">Issued</option>
                <option value="transfered">Transfered</option>
                <option value="disposed">Disposed</option>
            </select>
        </div>

        <!-- Optional Section: Room Number -->
        <div class="form-group">
            <label for="roomNumber">Room Number <span class="optional-label">(Optional)</span></label>
            <input type="text" id="roomNumber" placeholder="e.g. Room 402, Lab A">
        </div>

        <!-- Optional Section: Reason -->
        <div class="form-group">
            <label for="reason">Reason <span class="optional-label">(Optional)</span></label>
            <textarea id="reason" placeholder="State the purpose or reason for release..."></textarea>
        </div>

        <button type="submit" class="btn-submit">Submit Entry</button>
    </form>

    <div id="statusMessage" class="message"></div>
</div>

<script>
    // DATA SOURCE
    const inventoryDatabase = [
        { item: "Laptop Power Cable", uom: "piece" },
        { item: "A4 Copy Paper", uom: "ream" },
        { item: "Ethernet Cord (10m)", uom: "pack" },
        { item: "Industrial Lubricant", uom: "liter" },
        { item: "Steel Brackets", uom: "kilogram" },
        { item: "Bubble Wrap", uom: "roll" }
    ];

    const itemSelect = document.getElementById('releasedItem');
    const uomInput = document.getElementById('unitOfMeasure');
    const form = document.getElementById('dataEntryForm');
    const statusMsg = document.getElementById('statusMessage');

    // Populating Dropdown
    inventoryDatabase.sort((a, b) => a.item.localeCompare(b.item));
    inventoryDatabase.forEach(entry => {
        const option = document.createElement('option');
        option.value = entry.item;
        option.textContent = entry.item;
        itemSelect.appendChild(option);
    });

    // Auto-update UOM
    itemSelect.addEventListener('change', function() {
        const selectedItem = this.value;
        const matched = inventoryDatabase.find(entry => entry.item === selectedItem);
        uomInput.value = matched ? matched.uom : '';
    });

    // Submission handler
    form.addEventListener('submit', function(e) {
        e.preventDefault();

        const submissionData = {
            requestor: document.getElementById('requestor').value,
            item: itemSelect.value,
            uom: uomInput.value,
            quantity: Number(document.getElementById('quantity').value),
            action: document.getElementById('action').value,
            roomNumber: document.getElementById('roomNumber').value || null, // Capture if filled, else null
            reason: document.getElementById('reason').value || null,         // Capture if filled, else null
            timestamp: new Date().toISOString()
        };

        console.log("Data Submitted:", submissionData);

        // Feedback
        statusMsg.textContent = "Data recorded successfully!";
        statusMsg.classList.add('success');
        
        form.reset();
        uomInput.value = ''; // Clean readonly input manually
        
        setTimeout(() => {
            statusMsg.classList.remove('success');
            statusMsg.textContent = '';
        }, 4000);
    });
</script>

</body>
</html>
